{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MedicAssist FHIR R4 Bundle Schema",
  "description": "JSON Schema to validate the subset of FHIR R4 resources generated by MedicAssist.",
  "type": "object",
  "required": [
    "resourceType",
    "type",
    "entry"
  ],
  "properties": {
    "resourceType": {
      "type": "string",
      "const": "Bundle"
    },
    "type": {
      "type": "string",
      "const": "collection"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "entry": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "resource"
        ],
        "properties": {
          "resource": {
            "type": "object",
            "required": [
              "resourceType"
            ],
            "properties": {
              "resourceType": {
                "type": "string"
              }
            },
            "oneOf": [
              {
                "$ref": "#/definitions/Patient"
              },
              {
                "$ref": "#/definitions/Encounter"
              },
              {
                "$ref": "#/definitions/Condition"
              },
              {
                "$ref": "#/definitions/Observation"
              },
              {
                "$ref": "#/definitions/Procedure"
              }
            ]
          }
        }
      }
    }
  },
  "definitions": {
    "Patient": {
      "type": "object",
      "required": [
        "resourceType",
        "id"
      ],
      "properties": {
        "resourceType": {
          "type": "string",
          "const": "Patient"
        },
        "id": {
          "type": "string"
        },
        "gender": {
          "type": "string",
          "enum": [
            "male",
            "female",
            "other",
            "unknown"
          ]
        },
        "estimatedAge": {
          "type": "integer"
        },
        "birthDate": {
          "type": "string"
        }
      }
    },
    "Encounter": {
      "type": "object",
      "required": [
        "resourceType",
        "id",
        "status",
        "class",
        "subject",
        "priority"
      ],
      "properties": {
        "resourceType": {
          "type": "string",
          "const": "Encounter"
        },
        "id": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "const": "in-progress"
        },
        "class": {
          "type": "object",
          "required": [
            "code"
          ],
          "properties": {
            "code": {
              "type": "string",
              "const": "EMER"
            },
            "display": {
              "type": "string"
            }
          }
        },
        "subject": {
          "type": "object",
          "required": [
            "reference"
          ],
          "properties": {
            "reference": {
              "type": "string",
              "pattern": "^Patient/.*$"
            }
          }
        },
        "priority": {
          "type": "object",
          "required": [
            "coding"
          ],
          "properties": {
            "coding": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": [
                  "system",
                  "code"
                ],
                "properties": {
                  "system": {
                    "type": "string"
                  },
                  "code": {
                    "type": "string",
                    "enum": [
                      "R",
                      "Y",
                      "G",
                      "B",
                      "A"
                    ]
                  },
                  "display": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "period": {
          "type": "object",
          "required": [
            "start"
          ],
          "properties": {
            "start": {
              "type": "string"
            }
          }
        },
        "location": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "location"
            ],
            "properties": {
              "location": {
                "type": "object",
                "required": [
                  "display"
                ],
                "properties": {
                  "display": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    },
    "Condition": {
      "type": "object",
      "required": [
        "resourceType",
        "id",
        "clinicalStatus",
        "code",
        "subject"
      ],
      "properties": {
        "resourceType": {
          "type": "string",
          "const": "Condition"
        },
        "id": {
          "type": "string"
        },
        "clinicalStatus": {
          "type": "object",
          "required": [
            "coding"
          ],
          "properties": {
            "coding": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "code"
                ],
                "properties": {
                  "code": {
                    "type": "string",
                    "const": "active"
                  }
                }
              }
            }
          }
        },
        "code": {
          "type": "object",
          "required": [
            "text"
          ],
          "properties": {
            "text": {
              "type": "string"
            }
          }
        },
        "subject": {
          "type": "object",
          "required": [
            "reference"
          ],
          "properties": {
            "reference": {
              "type": "string",
              "pattern": "^Patient/.*$"
            }
          }
        },
        "bodySite": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "text"
            ],
            "properties": {
              "text": {
                "type": "string"
              }
            }
          }
        },
        "severity": {
          "type": "object",
          "required": [
            "coding",
            "text"
          ],
          "properties": {
            "coding": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "code",
                  "display"
                ],
                "properties": {
                  "code": {
                    "type": "string",
                    "enum": [
                      "mild",
                      "moderate",
                      "severe"
                    ]
                  },
                  "display": {
                    "type": "string"
                  }
                }
              }
            },
            "text": {
              "type": "string"
            }
          }
        }
      }
    },
    "Observation": {
      "type": "object",
      "required": [
        "resourceType",
        "id",
        "status",
        "code",
        "subject"
      ],
      "properties": {
        "resourceType": {
          "type": "string",
          "const": "Observation"
        },
        "id": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "const": "preliminary"
        },
        "code": {
          "type": "object",
          "required": [
            "coding",
            "text"
          ],
          "properties": {
            "coding": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "system",
                  "code",
                  "display"
                ],
                "properties": {
                  "system": {
                    "type": "string"
                  },
                  "code": {
                    "type": "string"
                  },
                  "display": {
                    "type": "string"
                  }
                }
              }
            },
            "text": {
              "type": "string"
            }
          }
        },
        "subject": {
          "type": "object",
          "required": [
            "reference"
          ],
          "properties": {
            "reference": {
              "type": "string",
              "pattern": "^Patient/.*$"
            }
          }
        },
        "valueQuantity": {
          "type": "object",
          "required": [
            "value",
            "unit"
          ],
          "properties": {
            "value": {
              "type": "number"
            },
            "unit": {
              "type": "string"
            }
          }
        },
        "valueString": {
          "type": "string"
        },
        "effectiveDateTime": {
          "type": "string"
        }
      }
    },
    "Procedure": {
      "type": "object",
      "required": [
        "resourceType",
        "id",
        "status",
        "code",
        "subject"
      ],
      "properties": {
        "resourceType": {
          "type": "string",
          "const": "Procedure"
        },
        "id": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "code": {
          "type": "object",
          "required": [
            "text"
          ],
          "properties": {
            "text": {
              "type": "string"
            }
          }
        },
        "subject": {
          "type": "object",
          "required": [
            "reference"
          ],
          "properties": {
            "reference": {
              "type": "string",
              "pattern": "^Patient/.*$"
            }
          }
        },
        "performedDateTime": {
          "type": "string"
        }
      }
    }
  }
}
